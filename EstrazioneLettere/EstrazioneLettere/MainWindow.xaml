        <TextBox x:Name="txtParola" HorizontalAlignment="Left" Margin="277,100,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" IsEnabled="False" Width="209" Height="74" FontSize="24"/>
