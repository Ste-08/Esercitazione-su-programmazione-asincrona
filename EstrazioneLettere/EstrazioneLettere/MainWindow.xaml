<Window x:Class="EstrazioneLettere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EstrazioneLettere"
        mc:Ignorable="d"
        Title="MainWindow" Height="465" Width="800">
    <Grid x:Name="btnStart">

        <!--Bottoni-->
        <Button Content="Inizia" HorizontalAlignment="Left" Margin="46,328,0,0" VerticalAlignment="Top" Height="89" Width="185" Click="Button_ClickInizia" FontSize="24" Background="#FF17E3E8"/>
        <Button x:Name="btnEstraiLettera" Content="Estrai" HorizontalAlignment="Left" Margin="46,217,0,0" VerticalAlignment="Top" Height="89" Width="185" Click="Button_ClickEstrai" FontSize="24" Background="#FF1BA6FF"/>
        <Button x:Name="btnPiuCaratteri" Content="+" HorizontalAlignment="Left" Margin="282,320,0,0" VerticalAlignment="Top" Height="40" Width="66" Click="btnPiuCaratteri_Click" FontSize="24" Background="#FF00C100"/>
        <Button x:Name="btnMenoCaratteri" Content="-" HorizontalAlignment="Left" Margin="388,320,0,0" VerticalAlignment="Top" Height="40" Width="70" Click="btnMenoCaratteri_Click" FontSize="26" Background="#FFF10000"/>

        <!--Label-->
        <Label x:Name="lblLettera" Content="A" HorizontalAlignment="Left" Margin="71,58,0,0" VerticalAlignment="Top" Height="99" Width="135" FontSize="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <Label Content="Numero caratteri da estrarre" HorizontalAlignment="Left" Margin="262,213,0,0" VerticalAlignment="Top" Height="35" Width="216" FontSize="16"/>
        <Label Content="Caratteri per parola" HorizontalAlignment="Left" Height="30" Margin="293,23,0,0" VerticalAlignment="Top" Width="155" FontSize="16"/>
        <Label Content="Carattere" HorizontalAlignment="Left" Height="30" Margin="100,23,0,0" VerticalAlignment="Top" Width="76" FontSize="16"/>

        <!--List box-->
        <ListBox x:Name="lstParole"  Margin="510,25,10,32" FontSize="16"/>

        <!--Text box-->
        <TextBox x:Name="txtParola" HorizontalAlignment="Left" Margin="266,70,0,0" TextWrapping="Wrap" Text="Vuoto" VerticalAlignment="Top" IsEnabled="False" Width="209" Height="74" FontSize="24" Foreground="Black" />
        <TextBox x:Name="txtNumeroCaratteri" HorizontalAlignment="Left" Margin="282,268,0,0" TextWrapping="Wrap" IsEnabled="True" Text="5" VerticalAlignment="Top" Width="176" Height="38" FontSize="24" TextChanged="txtNumeroCaratteri_TextChanged"/>
        <Rectangle HorizontalAlignment="Left" Height="99" Margin="73,58,0,0" Stroke="Black" VerticalAlignment="Top" Width="130"/>

    </Grid>
</Window>
